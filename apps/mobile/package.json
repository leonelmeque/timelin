  "scripts": {
    "build:ios:dev": "eas build --platform=ios --local --profile=development:simulator",
    "build:android:dev": "eas build --platform=android --local --profile=development:simulator",
    "run:build": "ts-node ./scripts/actions/build.ts",
    "run:install": "ts-node ./scripts/actions/install.ts",
    "run:clean": "ts-node ./scripts/actions/clean.ts",
    "todo-cli": "ts-node ./scripts/cli.ts",
    "push": "git push origin $(git branch --show-current)",
    "server": "json-server --watch --port=3001 ./data.json",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "tests": "jest",
    "storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start",
    "storybook:ios": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo run:ios",
    "storybook:web": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook --url http://localhost:6006",
    "maestro": "maestro test .maestro/",
    "maestro:smoke": "maestro test --include-tags smoke .maestro/"
  }
