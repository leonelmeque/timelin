{
  "preset": "react-native",
  "setupFilesAfterEnv": [
    "@babel/preset-typescript"
  ],
  "moduleNameMapper": {
    "^~/(.*)$": "<rootDir>/src/$1",
    "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2)$": "<rootDir>/__mocks__/fileMock.js"
  },
  "testPathIgnorePatterns": ["/node_modules/", "/e2e/"],
  "coverageThreshold": {
    "global": {
      "branches": 80,
      "functions": 80,
      "lines": 80
    }
  }
}
